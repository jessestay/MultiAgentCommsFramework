{
  "name": "multi-agent-comms-framework",
  "version": "2.0.0",
  "description": "MACF — AI team framework: shared core, swappable AI backends, multiple platform adapters (Slack, Cursor MCP, Discord, Teams). Open source.",
  "private": true,
  "scripts": {
    "start:slack": "node slack-agents/index.js",
    "start:mcp":   "node adapters/mcp/index.js",
