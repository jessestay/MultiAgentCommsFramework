    "lint":        "node --check slack-agents/agents/*.js slack-agents/utils/*.js slack-agents/index.js slack-agents/config.js"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "ai-agents", "multi-agent", "slack-bot", "mcp", "claude",
    "anthropic", "cursor", "open-source", "framework"
  ],
  "author": "Jesse Stay",
  "license": "MIT",
  "dependencies": {
    "node-fetch": "^3.3.2"
  }
}
