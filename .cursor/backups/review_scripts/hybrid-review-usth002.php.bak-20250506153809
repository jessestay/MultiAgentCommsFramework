/**
 * Reset review status
 *
 * @param ReviewManager $reviewManager Review manager
 */
function resetReviewStatus( ReviewManager $reviewManager ) {
	echo 'Resetting review status for ' . USER_STORY_ID . "...\n";

	if ( ! confirm( "⚠️  This will reset ALL review statuses to 'pending'. Continue?" ) ) {
		echo "Operation canceled.\n";
		exit( 0 );
	}

	$reviewManager->resetAllReviewStatuses();

	echo "✅ All review statuses reset to 'pending'.\n";
}

/**
 * Find theme files for US-TH-002
 *
 * @return array Theme files
 */
function findThemeFiles() {
	$files     = array();
	$basePaths = array(
		__DIR__ . '/../../austin-shows-theme',
		__DIR__ . '/../../assets',
		__DIR__ . '/../../src',
	);

	$extensions = array( 'php', 'css', 'js', 'html' );

	echo "Searching for theme files...\n";

	foreach ( $basePaths as $basePath ) {
		if ( ! is_dir( $basePath ) ) {
			continue;
		}

		// Find files recursively in the base path
		$directoryIterator = new RecursiveDirectoryIterator( $basePath );
		$iterator          = new RecursiveIteratorIterator( $directoryIterator );

		foreach ( $iterator as $file ) {
			if ( $file->isFile() ) {
				$extension = $file->getExtension();

				if ( in_array( $extension, $extensions ) ) {
					$files[] = $file->getPathname();
				}
			}
		}
	}

	echo 'Found ' . count( $files ) . " implementation files.\n";

	return $files;
}

/**
 * Find screenshots for US-TH-002
 *
 * @return array Screenshots (name => path)
 */
function findScreenshots() {
	$screenshots    = array();
	$screenshotsDir = __DIR__ . '/../../docs/user-stories/sprint-3/' . USER_STORY_ID . '/screenshots';

	if ( ! is_dir( $screenshotsDir ) ) {
		echo "Screenshots directory not found: $screenshotsDir\n";
		return $screenshots;
	}

	$files = scandir( $screenshotsDir );

	foreach ( $files as $file ) {
		$extension = pathinfo( $file, PATHINFO_EXTENSION );

		if ( in_array( strtolower( $extension ), array( 'jpg', 'jpeg', 'png', 'gif' ) ) ) {
			$name                 = pathinfo( $file, PATHINFO_FILENAME );
			$screenshots[ $name ] = $screenshotsDir . '/' . $file;
		}
	}

	echo 'Found ' . count( $screenshots ) . " screenshots.\n";

	return $screenshots;
}

/**
 * Ask for confirmation
 *
 * @param string $question Question to ask
 * @return bool User confirmed
 */
function confirm( $question ) {
	echo $question . ' (y/n) ';
	$handle = fopen( 'php://stdin', 'r' );
	$line   = fgets( $handle );
	fclose( $handle );

	return strtolower( trim( $line ) ) === 'y';
}
