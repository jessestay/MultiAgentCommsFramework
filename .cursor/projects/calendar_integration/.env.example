# Google API credentials
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8080/oauth2callback

# Token storage configuration
TOKEN_ENCRYPTION_KEY=generate_a_secure_random_key
TOKEN_STORAGE_PATH=./tokens

# API configuration
CALENDAR_API_SCOPES=https://www.googleapis.com/auth/calendar,https://www.googleapis.com/auth/calendar.events
TASKS_API_SCOPES=https://www.googleapis.com/auth/tasks

# Privacy settings
PRIVACY_FILTER_ENABLED=true
PII_DETECTION_LEVEL=medium  # Options: low, medium, high

# Logging configuration
LOG_LEVEL=INFO  # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE=./logs/calendar_integration.log 