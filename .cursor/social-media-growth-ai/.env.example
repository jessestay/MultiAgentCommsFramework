# Social Media Growth AI - Environment Variables

# Facebook API Configuration
FACEBOOK_APP_ID=your_app_id_here
FACEBOOK_APP_SECRET=your_app_secret_here
FACEBOOK_ACCESS_TOKEN=your_access_token_here
FACEBOOK_PAGE_ID=your_page_id_here

# Development Configuration
DEBUG=True
ENVIRONMENT=development
LOG_LEVEL=DEBUG

# FastAPI Server Configuration
HOST=localhost
PORT=8000

# AI Configuration
OPENAI_API_KEY=your_openai_api_key_here
MODEL_NAME=gpt-4
MAX_TOKENS=2000

# Database Configuration
DATABASE_URL=sqlite:///./social_media_growth.db

# Rate Limiting
API_RATE_LIMIT=100
API_RATE_LIMIT_PERIOD=3600  # 1 hour in seconds

# Content Generation Settings
DEFAULT_CONTENT_TONE=professional
DEFAULT_CONTENT_LENGTH=medium  # short, medium, long
HASHTAG_COUNT=5

# Scheduling
DEFAULT_TIMEZONE=UTC
POST_QUEUE_SIZE=100
RETRY_ATTEMPTS=3
RETRY_DELAY=300  # 5 minutes in seconds 