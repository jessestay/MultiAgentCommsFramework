{
  "name": "Google Sheets Write Subworkflow",
  "nodes": [
    {
      "parameters": {},
      "id": "execute-trigger-002",
      "name": "Execute Workflow Trigger",
      "type": "n8n-nodes-base.executeWorkflowTrigger",
      "typeVersion": 1.1,
      "position": [240, 320]
    },
    {
      "parameters": {
        "operation": "append",
        "documentId": "={{ $json.sheetId }}",
        "sheetName": "={{ $json.sheetName || 'Sheet1' }}",
        "columns": {
          "mappingMode": "defineBelow",
          "value": "={{ $json.values }}"
        }
      },
      "id": "sheets-write-001",
      "name": "Write Google Sheet",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4,
      "position": [460, 320]
    }
  ],
  "connections": {
    "Execute Workflow Trigger": {
      "main": [
        [
          {
            "node": "Write Google Sheet",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  }
}
