# Slack — Bot Token (xoxb-...) from OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# Slack — Signing Secret from Basic Information
SLACK_SIGNING_SECRET=your-signing-secret-here

# Slack — App-Level Token (xapp-...) from Basic Information > App-Level Tokens
# Requires connections:write scope. This is what enables Socket Mode.
SLACK_APP_TOKEN=xapp-your-app-token-here

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-key-here

# GitHub — Personal Access Token (read:repo scope is enough)
GITHUB_TOKEN=ghp-your-token-here

# Optional: Upstash Redis URL (if you want cloud state instead of local JSON)
# UPSTASH_REDIS_URL=https://xxx.upstash.io
# UPSTASH_REDIS_TOKEN=your-token-here

# Environment
NODE_ENV=production
