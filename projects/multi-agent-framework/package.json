{
  "name": "multiagent-communications-framework",
  "displayName": "Multi-agent Communications Framework",
  "description": "Role-based communication system and Agile framework for AI-assisted development",
  "version": "0.1.0",
  "publisher": "automaticjesse",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "multiagent.switchRole",
        "title": "Multi-agent: Switch Role"
      },
      {
        "command": "multiagent.showRoleSelector",
        "title": "Multi-agent: Show Role Selector"
      },
      {
        "command": "multiagent.insertTemplate",
        "title": "Multi-agent: Insert Template"
      },
      {
        "command": "multiagent.createSprint",
        "title": "Multi-agent: Create New Sprint"
      },
      {
        "command": "multiagent.createUserStory",
        "title": "Multi-agent: Create User Story"
      }
    ],
    "keybindings": [
      {
        "command": "multiagent.switchRole",
        "key": "ctrl+alt+r",
        "mac": "cmd+alt+r"
      },
      {
        "command": "multiagent.insertTemplate",
        "key": "ctrl+alt+t",
        "mac": "cmd+alt+t"
      }
    ],
    "configuration": {
      "title": "Multi-agent Communications Framework",
      "properties": {
        "multiagent.enableRoleSystem": {
          "type": "boolean",
          "default": true,
          "description": "Enable the role-based communication system"
        },
        "multiagent.defaultRole": {
          "type": "string",
          "default": "ES",
          "enum": [
            "ES",
            "SET",
            "CTW",
            "DES",
            "DRC"
          ],
          "description": "Default role to activate on startup"
        },
        "multiagent.enableVisualIdentity": {
          "type": "boolean",
          "default": true,
          "description": "Enable visual identity styling for roles"
        },
        "multiagent.maxHistoryLength": {
          "type": "number",
          "default": 100,
          "description": "Maximum number of messages to keep in history"
        },
        "multiagent.templateDirectory": {
          "type": "string",
          "default": "",
          "description": "Custom directory for role templates"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "multiagent-sidebar",
          "title": "Multi-agent Framework",
          "icon": "resources/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "multiagent-sidebar": [
        {
          "id": "multiagent.roleSelector",
          "name": "Roles"
        },
        {
          "id": "multiagent.agileBoard",
          "name": "Agile Board"
        },
        {
          "id": "multiagent.templates",
          "name": "Templates"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "lint": "eslint src --ext ts",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "devDependencies": {
    "@types/glob": "^7.1.4",
    "@types/jest": "^27.0.1",
    "@types/node": "^16.10.0",
    "@types/vscode": "^1.60.0",
    "@typescript-eslint/eslint-plugin": "^5.0.0",
    "@typescript-eslint/parser": "^5.0.0",
    "eslint": "^8.0.0",
    "glob": "^7.2.0",
    "jest": "^27.2.4",
    "ts-jest": "^27.0.5",
    "ts-loader": "^9.2.6",
    "typescript": "^4.4.3",
    "webpack": "^5.58.1",
    "webpack-cli": "^4.9.0"
  },
  "dependencies": {
    "multiagent-communications-framework": "file:",
    "vscode-languageclient": "^7.0.0"
  }
}
