## Examples

### Example 1: Adding MCP to Schedule Workflow

```json
{
  "nodes": [
    {
      "type": "n8n-nodes-base.scheduleTrigger",
      "name": "Schedule Trigger"
    },
    {
      "type": "@n8n/n8n-nodes-langchain.mcpTrigger",
      "name": "MCP Server Trigger",
      "parameters": {
        "path": "workflow-name"
      }
    },
    {
      "type": "n8n-nodes-base.function",
      "name": "MCP Adapter (Schedule)",
      "parameters": {
        "functionCode": "// MCP Server Trigger outputs: { tool: string, arguments: object }\n// Transform to empty data for nodes that generate their own data\nreturn [{ json: {} }];"
      }
    },
    {
      "type": "n8n-nodes-base.set",
      "name": "Process Data"
    }
  ],
  "connections": {
    "Schedule Trigger": {
      "main": [[{"node": "Process Data"}]]
    },
    "MCP Server Trigger": {
      "main": [[{"node": "MCP Adapter (Schedule)"}]]
    },
    "MCP Adapter (Schedule)": {
      "main": [[{"node": "Process Data"}]]
    }
  }
}
```

