{
  "name": "browser-demo",
  "version": "0.1.0",
  "description": "MCP bindings for browser demo generation using Auth Broker + Runner",
  "tools": [
    {
      "name": "generateDemo",
      "type": "http",
      "method": "POST",
      "url": "http://localhost:8788/generate",
      "inputSchema": {
        "type": "object",
        "properties": {
          "transcript": { "type": "string" },
          "domains": { "type": "array", "items": { "type": "string" } },
          "tenant": { "type": "string" }
        },
        "required": ["transcript"]
      }
    },
    {
      "name": "getStatus",
      "type": "http",
      "method": "GET",
      "url": "http://localhost:8788/status/{jobId}",
      "pathParams": ["jobId"]
    },
    {
      "name": "getConnectLink",
      "type": "http",
      "method": "GET",
      "url": "http://localhost:8788/connect-link?domain={domain}",
      "inputSchema": {
        "type": "object",
        "properties": {
          "domain": { "type": "string" }
        },
        "required": ["domain"]
      }
    }
  ]
}

